      "b": {
        "attribute_type": "FormulaMetric",
        "ref": "account_meeting_acceleration",
        "description": "Meeting acceleration (7d vs 30d meeting ratio)"
      },
      "c": {
        "attribute_type": "FormulaMetric",
        "ref": "account_email_acceleration",
        "description": "Email acceleration (7d vs 30d inbound email ratio)"
      }
    }
  },
  "display_name": "Engagement Momentum Score",
  "description": "Composite score measuring whether account engagement is accelerating, stable, or declining. Combines overall activity momentum with meeting-specific and email-specific acceleration signals to detect trajectory changes early.",
  "coaching_text": "Above 1.20 = Surging — engagement is accelerating rapidly, potential buying signal. 0.80-1.20 = Stable — consistent engagement, monitor for shifts. Below 0.80 = Declining — engagement fading, investigate and re-engage.",
  "active": true,
  "show": true,
  "source": "people_ai",
  "_meta": {
    "category": "engagement_momentum",
    "tier": "composite",
    "insight_types": ["engagement_momentum"],
    "component_metrics": [
      "account_engagement_momentum",
      "account_meeting_acceleration",
      "account_email_acceleration"
    ],
    "weights": {
      "engagement_momentum": 0.40,
      "meeting_acceleration": 0.30,
      "email_acceleration": 0.30
